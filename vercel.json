{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/env-generator run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/env-generator/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
